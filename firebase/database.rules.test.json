{
  "rules": {
    ".read": false,
    ".write": false,
    "familyMembers": {
      "$familyId": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.isBoolean()"
        }
      }
    },
    "families": {
      "$familyId": {
        ".read": "auth != null",
        ".write": false,
        "ownerUid": {
          ".write": "auth != null && (!data.exists() || data.val() === auth.uid)",
          ".validate": "newData.val() === null || (newData.isString() && newData.val() === auth.uid)"
        },
        "ownerCodeHash": {
          ".write": "auth != null && newData.parent().child('ownerUid').val() === auth.uid",
          ".validate": "newData.isString() && newData.val().matches(/^sha256:[0-9a-f]{64}$/)"
        },
        "ownerProfileId": {
          ".write": "auth != null",
          ".validate": "newData.val() === null || newData.isString()"
        },
        "updatedAt": {
          ".write": "auth != null",
          ".validate": "newData.isNumber()"
        },
        "profiles": {
          "$profileId": {
            ".write": "auth != null",
            "surname": {
              ".validate": "newData.isString() && newData.val().length <= 80"
            },
            "role": {
              ".validate": "newData.val() === 'proprietaire' || newData.val() === 'utilisateur'"
            },
            "createdAt": {
              ".validate": "newData.isNumber()"
            },
            "lastSyncAt": {
              ".validate": "newData.isNumber()"
            },
            "passwordHash": {
              ".validate": "newData.val() === null || (newData.isString() && newData.val().matches(/^sha256:[0-9a-f]{64}$/))"
            },
            "recoveryHash": {
              ".validate": "newData.val() === null || (newData.isString() && newData.val().matches(/^sha256:[0-9a-f]{64}$/))"
            },
            "recoveryConfiguredAt": {
              ".validate": "newData.val() === null || newData.isNumber()"
            },
            "gender": {
              ".validate": "newData.val() === 'unspecified' || newData.val() === 'male' || newData.val() === 'female'"
            },
            "householdRole": {
              ".validate": "newData.val() === 'member' || newData.val() === 'parent' || newData.val() === 'child'"
            },
            "customChecklistItems": {
              "$itemId": {
                ".validate": "newData.hasChildren(['id','label','categoryId']) && newData.child('id').isString() && newData.child('label').isString() && newData.child('categoryId').isString() && (!newData.child('genderTargets').exists() || newData.child('genderTargets').val() === 'all' || newData.child('genderTargets').val() === 'male' || newData.child('genderTargets').val() === 'female') && (!newData.child('householdRoleTargets').exists() || newData.child('householdRoleTargets').val() === 'all' || newData.child('householdRoleTargets').val() === 'parent' || newData.child('householdRoleTargets').val() === 'child') && (!newData.child('ownerOnly').exists() || newData.child('ownerOnly').isBoolean()) && (!newData.child('visibleToProfileId').exists() || newData.child('visibleToProfileId').isString())"
              }
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "checklistCatalogAdditions": {
          ".write": "auth != null && newData.parent().child('ownerUid').val() === auth.uid",
          "$itemId": {
            ".validate": "newData.hasChildren(['id','label','categoryId']) && newData.child('id').isString() && newData.child('label').isString() && newData.child('categoryId').isString() && (!newData.child('genderTargets').exists() || newData.child('genderTargets').val() === 'all' || newData.child('genderTargets').val() === 'male' || newData.child('genderTargets').val() === 'female') && (!newData.child('householdRoleTargets').exists() || newData.child('householdRoleTargets').val() === 'all' || newData.child('householdRoleTargets').val() === 'parent' || newData.child('householdRoleTargets').val() === 'child') && (!newData.child('ownerOnly').exists() || newData.child('ownerOnly').isBoolean()) && (!newData.child('visibleToProfileId').exists() || newData.child('visibleToProfileId').isString())"
          }
        },
        "checklistCatalogRemovals": {
          ".write": "auth != null && newData.parent().child('ownerUid').val() === auth.uid",
          "$itemId": {
            ".validate": "newData.isBoolean()"
          }
        },
        "checklists": {
          "$profileId": {
            ".write": "auth != null",
            "$itemId": {
              ".validate": "newData.isBoolean()"
            }
          }
        },
        "gameResults": {
          "$profileId": {
            ".write": "auth != null",
            "$index": {
              ".validate": "newData.hasChildren(['day','location','quizScore','correctCount','riddleSolved','challengeDone','durationSec','totalScore','completedAt'])"
            }
          }
        },
        "phase": {
          ".write": "auth != null && newData.parent().child('ownerUid').val() === auth.uid",
          ".validate": "newData.val() === 'before' || newData.val() === 'during'"
        },
        "tripStartDate": {
          ".write": "auth != null && newData.parent().child('ownerUid').val() === auth.uid",
          ".validate": "newData.val() === null || (newData.isString() && newData.val().matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/))"
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}
