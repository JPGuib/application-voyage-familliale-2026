# -----------------------------------------------------------------------------
# Application de voyage familiale - modele de .env.local
# -----------------------------------------------------------------------------
# 1) Copiez ce fichier vers .env.local
# 2) Renseignez les valeurs depuis Firebase Console > Project settings
# 3) Reportez exactement les memes variables dans Vercel (Production/Preview)
# -----------------------------------------------------------------------------

# Firebase Web app config
# Exemple de format: AIza... (ne pas commit de vraies cles)
VITE_FIREBASE_API_KEY=__FIREBASE_API_KEY__

# Exemple de format: votre-projet.firebaseapp.com
VITE_FIREBASE_AUTH_DOMAIN=__FIREBASE_AUTH_DOMAIN__

# Exemple de format: https://votre-projet-default-rtdb.europe-west1.firebasedatabase.app
VITE_FIREBASE_DATABASE_URL=__FIREBASE_DATABASE_URL__

# Exemple de format: votre-projet
VITE_FIREBASE_PROJECT_ID=__FIREBASE_PROJECT_ID__

# Exemple de format: 1:1234567890:web:abcdef123456
VITE_FIREBASE_APP_ID=__FIREBASE_APP_ID__

# IMPORTANT: meme valeur sur tous les appareils de la famille
# (iPhone, iPad, Android, desktop) pour partager le meme espace de donnees.
VITE_FAMILY_SYNC_ID=famille-voyage-2026

# Note:
# - Si ces variables ne sont pas renseignees, l'app fonctionne en mode local
#   (pas de synchronisation multi-appareils).
